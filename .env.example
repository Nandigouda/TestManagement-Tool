# ==================== SERVER DEPLOYMENT ENVIRONMENT VARIABLES ====================
# Copy this file to .env and update values for your production server
# DO NOT commit .env to version control - it contains sensitive data

# ==================== SERVER CONFIGURATION ====================
SERVER_PORT=8080
SPRING_PROFILE=prod

# ==================== DATABASE CONFIGURATION ====================
# PostgreSQL Database Credentials
DB_HOST=your-database-server.com
DB_PORT=5432
DB_NAME=pgvector
DB_USER=postgres_user
DB_PASSWORD=your-secure-database-password

# ==================== SECURITY & ENCRYPTION ====================
# IMPORTANT: Generate a strong encryption key for production
# Command to generate: openssl rand -base64 32
ENCRYPTION_SECRET_KEY=your-base64-encoded-32-byte-encryption-key

# ==================== CORS CONFIGURATION ====================
# Set to your production frontend URL(s)
# Multiple URLs can be comma-separated
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ==================== JIRA INTEGRATION (Optional) ====================
JIRA_BASE_URL=https://your-jira-instance.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_USERNAME=your-jira-username

# ==================== CACHE CONFIGURATION ====================
CACHE_TTL=5

# ==================== SECURITY SETTINGS ====================
# Set to true when using HTTPS in production
SESSION_COOKIE_SECURE=false

# ==================== API DOCUMENTATION ====================
# Disable Swagger UI in production for security
SWAGGER_ENABLED=false

# ==================== AZURE OPENAI CONFIGURATION (Optional) ====================
AZURE_OPENAI_ENABLED=true
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_GPT4=gpt4-turbo
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ==================== OPENAI CONFIGURATION (Optional, used if Azure is disabled) ====================
OPENAI_API_KEY=sk-your-openai-key
